<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/drawerContent"
    android:layout_width="300dp"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/white"
    android:layout_gravity="start">

    <!-- ═══ Blue Gradient Header ═══ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_drawer_header"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="52dp"
        android:paddingBottom="20dp">

        <!-- Avatar row + close button -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="20dp">

            <!-- Avatar -->
            <de.hdodenhof.circleimageview.CircleImageView
                android:id="@+id/ivDrawerAvatar"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:src="@drawable/ic_profile_placeholder"
                android:layout_marginEnd="12dp"
                android:contentDescription="Profile" />

            <!-- Name + role -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvDrawerName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:textColor="@color/white" />

                <TextView
                    android:id="@+id/tvDrawerEmail"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="12sp"
                    android:textColor="#BFDBFE" />
            </LinearLayout>

            <!-- Close X button -->
            <ImageView
                android:id="@+id/ivDrawerClose"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_white_20"
                android:src="@drawable/ic_close"
                android:tint="@color/white"
                android:padding="10dp"
                android:contentDescription="Close" />
        </LinearLayout>

        <!-- Quick Stats card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/bg_drawer_stats"
            android:padding="16dp">

            <!-- Balance -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:id="@+id/tvDrawerBalance"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="$0"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/white" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Balance"
                    android:textSize="11sp"
                    android:textColor="#BFDBFE" />
            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:background="#33FFFFFF" />

            <!-- Transactions -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:id="@+id/tvDrawerTransactions"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/white" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Transactions"
                    android:textSize="11sp"
                    android:textColor="#BFDBFE" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- ═══ Scrollable Navigation ═══ -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scrollbars="none"
        android:padding="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Navigation items group label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="NAVIGATION"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="@color/text_hint"
                android:letterSpacing="0.15"
                android:layout_marginStart="4dp"
                android:layout_marginBottom="6dp"
                android:layout_marginTop="8dp" />

            <!-- Home -->
            <LinearLayout
                android:id="@+id/drawerHome"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:background="@drawable/bg_drawer_item"
                android:layout_marginBottom="2dp">

                <FrameLayout android:layout_width="40dp" android:layout_height="40dp" android:layout_marginEnd="14dp">
                    <View android:layout_width="40dp" android:layout_height="40dp" android:background="@drawable/bg_stat_gray" />
                    <ImageView android:layout_width="20dp" android:layout_height="20dp" android:layout_gravity="center" android:src="@drawable/ic_home" android:tint="#6B7280" android:contentDescription="Home" />
                </FrameLayout>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Home" android:textSize="15sp" android:textStyle="bold" android:textColor="@color/text_primary" />
            </LinearLayout>

            <!-- My Cards -->
            <LinearLayout
                android:id="@+id/drawerMyCards"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:background="@drawable/bg_drawer_item"
                android:layout_marginBottom="2dp">

                <FrameLayout android:layout_width="40dp" android:layout_height="40dp" android:layout_marginEnd="14dp">
                    <View android:layout_width="40dp" android:layout_height="40dp" android:background="@drawable/bg_stat_gray" />
                    <ImageView android:layout_width="20dp" android:layout_height="20dp" android:layout_gravity="center" android:src="@drawable/ic_credit_card" android:tint="#6B7280" android:contentDescription="Cards" />
                </FrameLayout>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="My Cards" android:textSize="15sp" android:textStyle="bold" android:textColor="@color/text_primary" />
            </LinearLayout>

            <!-- Statistics -->
            <LinearLayout
                android:id="@+id/drawerStatistics"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:background="@drawable/bg_drawer_item"
                android:layout_marginBottom="2dp">

                <FrameLayout android:layout_width="40dp" android:layout_height="40dp" android:layout_marginEnd="14dp">
                    <View android:layout_width="40dp" android:layout_height="40dp" android:background="@drawable/bg_stat_gray" />
                    <ImageView android:layout_width="20dp" android:layout_height="20dp" android:layout_gravity="center" android:src="@drawable/ic_pie_chart" android:tint="#6B7280" android:contentDescription="Statistics" />
                </FrameLayout>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Statistics" android:textSize="15sp" android:textStyle="bold" android:textColor="@color/text_primary" />
            </LinearLayout>

            <!-- Send Money -->
            <LinearLayout
                android:id="@+id/drawerSendMoney"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:background="@drawable/bg_drawer_item"
                android:layout_marginBottom="2dp">

                <FrameLayout android:layout_width="40dp" android:layout_height="40dp" android:layout_marginEnd="14dp">
                    <View android:layout_width="40dp" android:layout_height="40dp" android:background="@drawable/bg_stat_gray" />
                    <ImageView android:layout_width="20dp" android:layout_height="20dp" android:layout_gravity="center" android:src="@drawable/ic_send" android:tint="#6B7280" android:contentDescription="Send Money" />
                </FrameLayout>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Send Money" android:textSize="15sp" android:textStyle="bold" android:textColor="@color/text_primary" />
            </LinearLayout>

            <!-- Top Up -->
            <LinearLayout
                android:id="@+id/drawerTopup"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:background="@drawable/bg_drawer_item"
                android:layout_marginBottom="2dp">

                <FrameLayout android:layout_width="40dp" android:layout_height="40dp" android:layout_marginEnd="14dp">
                    <View android:layout_width="40dp" android:layout_height="40dp" android:background="@drawable/bg_stat_gray" />
                    <ImageView android:layout_width="20dp" android:layout_height="20dp" android:layout_gravity="center" android:src="@drawable/ic_wallet" android:tint="#6B7280" android:contentDescription="Top Up" />
                </FrameLayout>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Top Up" android:textSize="15sp" android:textStyle="bold" android:textColor="@color/text_primary" />
            </LinearLayout>

            <!-- Notifications with badge -->
            <LinearLayout
                android:id="@+id/drawerNotifications"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:background="@drawable/bg_drawer_item"
                android:layout_marginBottom="2dp">

                <FrameLayout android:layout_width="40dp" android:layout_height="40dp" android:layout_marginEnd="14dp">
                    <View android:layout_width="40dp" android:layout_height="40dp" android:background="@drawable/bg_stat_gray" />
                    <ImageView android:layout_width="20dp" android:layout_height="20dp" android:layout_gravity="center" android:src="@drawable/ic_bell" android:tint="#6B7280" android:contentDescription="Notifications" />
                </FrameLayout>

                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Notifications" android:textSize="15sp" android:textStyle="bold" android:textColor="@color/text_primary" />

                <TextView
                    android:id="@+id/tvDrawerNotifBadge"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:gravity="center"
                    android:textSize="10sp"
                    android:textColor="@color/white"
                    android:textStyle="bold"
                    android:background="@drawable/bg_dot_active"
                    android:visibility="gone" />
            </LinearLayout>

            <!-- Divider + Account label -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="10dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ACCOUNT"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="@color/text_hint"
                android:letterSpacing="0.15"
                android:layout_marginStart="4dp"
                android:layout_marginBottom="6dp" />

            <!-- Profile -->
            <LinearLayout
                android:id="@+id/drawerProfile"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:background="@drawable/bg_drawer_item"
                android:layout_marginBottom="2dp">

                <FrameLayout android:layout_width="40dp" android:layout_height="40dp" android:layout_marginEnd="14dp">
                    <View android:layout_width="40dp" android:layout_height="40dp" android:background="@drawable/bg_stat_gray" />
                    <ImageView android:layout_width="20dp" android:layout_height="20dp" android:layout_gravity="center" android:src="@drawable/ic_person" android:tint="#6B7280" android:contentDescription="Profile" />
                </FrameLayout>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Profile" android:textSize="15sp" android:textStyle="bold" android:textColor="@color/text_primary" />
            </LinearLayout>

            <!-- Settings -->
            <LinearLayout
                android:id="@+id/drawerSettings"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:background="@drawable/bg_drawer_item"
                android:layout_marginBottom="2dp">

                <FrameLayout android:layout_width="40dp" android:layout_height="40dp" android:layout_marginEnd="14dp">
                    <View android:layout_width="40dp" android:layout_height="40dp" android:background="@drawable/bg_stat_gray" />
                    <ImageView android:layout_width="20dp" android:layout_height="20dp" android:layout_gravity="center" android:src="@drawable/ic_settings" android:tint="#6B7280" android:contentDescription="Settings" />
                </FrameLayout>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Settings" android:textSize="15sp" android:textStyle="bold" android:textColor="@color/text_primary" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- ═══ Logout Button ═══ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingBottom="24dp"
        android:paddingTop="8dp">

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider"
            android:layout_marginBottom="12dp" />

        <LinearLayout
            android:id="@+id/drawerLogout"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:background="@drawable/bg_logout_btn">

            <FrameLayout android:layout_width="40dp" android:layout_height="40dp" android:layout_marginEnd="14dp">
                <View android:layout_width="40dp" android:layout_height="40dp" android:background="@drawable/bg_stat_orange" />
                <ImageView android:layout_width="20dp" android:layout_height="20dp" android:layout_gravity="center" android:src="@drawable/ic_logout" android:tint="#DC2626" android:contentDescription="Logout" />
            </FrameLayout>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Logout" android:textSize="15sp" android:textStyle="bold" android:textColor="#DC2626" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
