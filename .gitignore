# ──────────────────────────────────────────────────────────
#  BankPick — .gitignore
# ──────────────────────────────────────────────────────────

# ── Android build outputs ──────────────────────────────────
android/build/
android/app/build/
android/**/build/

# ── Gradle wrapper & cache ─────────────────────────────────
android/.gradle/
.gradle/
gradle-app.setting
!gradle-wrapper.jar
!gradlew
!gradlew.bat

# ── Android Studio / IntelliJ IDEA ────────────────────────
.idea/
*.iml
*.iws
*.ipr
.idea/deploymentTargetSelector.xml
.idea/gradle.xml
.idea/misc.xml
.idea/modules.xml
.idea/vcs.xml
.idea/workspace.xml
.idea/navEditor.xml

# ── Local properties (machine-specific paths & secrets) ───
android/local.properties
local.properties

# ── APK / AAB / signing ────────────────────────────────────
*.apk
*.aab
*.ap_
*.dex
*.keystore
*.jks

# ── ProGuard ───────────────────────────────────────────────
proguard/
!proguard-rules.pro

# ── OS generated files ─────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini

# ── Node / React / Expo (app/ frontend) ───────────────────
app/node_modules/
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.expo/
dist/
web-build/
.env
.env.local
.env.*.local

# ── Misc project-level scratch ─────────────────────────────
smd.txt
*.txt
imports/
styles/
"google-services (2).json"

# ── Firebase – keep the real one, ignore duplicates ────────
# android/app/google-services.json  ← keep tracked (intentional)
google-services\ (2).json
