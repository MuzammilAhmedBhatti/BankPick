<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingStart="20dp"
    android:paddingEnd="20dp"
    android:paddingTop="14dp"
    android:paddingBottom="14dp"
    android:background="@drawable/bg_user_list_item"
    android:clickable="true"
    android:focusable="true">

    <!-- ── Red gradient avatar + initials ── -->
    <FrameLayout
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginEnd="16dp">

        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_avatar_red_gradient" />

        <TextView
            android:id="@+id/tvBlockedInitials"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="TM"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#991b1b" />
    </FrameLayout>

    <!-- ── Name & Email ── -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvBlockedUserName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="John Doe"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#1A1A2E"
            android:layout_marginBottom="2dp" />

        <TextView
            android:id="@+id/tvBlockedUserEmail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="john@example.com"
            android:textSize="12sp"
            android:textColor="#6B7280" />
    </LinearLayout>

    <!-- ── Unblock button ── -->
    <Button
        android:id="@+id/btnUnblockUser"
        android:layout_width="wrap_content"
        android:layout_height="36dp"
        android:text="Unblock"
        android:textAllCaps="false"
        android:textSize="13sp"
        android:textColor="#FFFFFF"
        android:background="@drawable/bg_btn_unblock"
        android:elevation="0dp"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:insetTop="0dp"
        android:insetBottom="0dp" />

</LinearLayout>
