<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_F0F4FF">

    <!-- Blue Gradient Header -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:background="@color/bg_2563EB">

        <!-- Subtle gradient overlay -->
        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_profile_header" />

        <!-- Header Row: Back / Title / Edit -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="48dp"
            android:paddingStart="20dp"
            android:paddingEnd="20dp">

            <!-- Back button -->
            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_white_20"
                android:src="@drawable/ic_chevron_left"
                android:padding="10dp"
                android:tint="@color/white"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:contentDescription="Back" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Profile"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:layout_centerInParent="true" />

            <!-- Edit button -->
            <ImageView
                android:id="@+id/btnEdit"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_white_20"
                android:src="@drawable/ic_edit3"
                android:padding="10dp"
                android:tint="@color/white"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:contentDescription="Edit Profile" />
        </RelativeLayout>
    </FrameLayout>

    <!-- Scrollable Content overlapping header -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="-64dp"
        android:clipToPadding="false"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingBottom="32dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- White Profile Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="8dp"
                app:cardBackgroundColor="@color/surface"
                xmlns:app="http://schemas.android.com/apk/res-auto">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <!-- Avatar + Name -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:layout_marginBottom="24dp">

                        <!-- Avatar with ring + green dot -->
                        <FrameLayout
                            android:layout_width="96dp"
                            android:layout_height="96dp"
                            android:layout_marginBottom="12dp">

                            <!-- Blue gradient ring -->
                            <View
                                android:layout_width="96dp"
                                android:layout_height="96dp"
                                android:background="@drawable/bg_avatar_ring" />

                            <!-- White inner ring -->
                            <View
                                android:layout_width="88dp"
                                android:layout_height="88dp"
                                android:layout_gravity="center"
                                android:background="@drawable/bg_circle_white_solid" />

                            <!-- Avatar image -->
                            <de.hdodenhof.circleimageview.CircleImageView
                                android:id="@+id/ivProfilePhoto"
                                android:layout_width="80dp"
                                android:layout_height="80dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_profile_placeholder"
                                android:contentDescription="Profile photo" />

                            <!-- Green online dot -->
                            <View
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:layout_gravity="bottom|end"
                                android:layout_marginEnd="4dp"
                                android:layout_marginBottom="4dp"
                                android:background="@drawable/bg_dot_green_bordered" />
                        </FrameLayout>

                        <!-- Name -->
                        <TextView
                            android:id="@+id/tvUserName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=""
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary"
                            android:layout_marginBottom="4dp" />

                        <!-- Email / role -->
                        <TextView
                            android:id="@+id/tvUserTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=""
                            android:textSize="14sp"
                            android:textColor="@color/text_secondary"
                            android:layout_marginBottom="6dp" />

                        <!-- Joined date -->
                        <TextView
                            android:id="@+id/tvJoinedDate"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=""
                            android:textSize="12sp"
                            android:textColor="@color/text_hint" />
                    </LinearLayout>

                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/bg_F3F4F6"
                        android:layout_marginBottom="20dp" />

                    <!-- Stats Grid -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <!-- Balance stat -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">

                            <FrameLayout
                                android:layout_width="48dp"
                                android:layout_height="48dp"
                                android:layout_marginBottom="8dp">
                                <View
                                    android:layout_width="48dp"
                                    android:layout_height="48dp"
                                    android:background="@drawable/bg_stat_blue" />
                                <ImageView
                                    android:layout_width="24dp"
                                    android:layout_height="24dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_wallet"
                                    android:tint="@color/tint_2563EB"
                                    android:contentDescription="Balance" />
                            </FrameLayout>

                            <TextView
                                android:id="@+id/tvStatBalance"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="$0"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:textColor="@color/text_primary" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Balance"
                                android:textSize="11sp"
                                android:textColor="@color/text_secondary" />
                        </LinearLayout>

                        <!-- Cards stat -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">

                            <FrameLayout
                                android:layout_width="48dp"
                                android:layout_height="48dp"
                                android:layout_marginBottom="8dp">
                                <View
                                    android:layout_width="48dp"
                                    android:layout_height="48dp"
                                    android:background="@drawable/bg_stat_purple" />
                                <ImageView
                                    android:layout_width="24dp"
                                    android:layout_height="24dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_credit_card"
                                    android:tint="@color/tint_7C3AED"
                                    android:contentDescription="Cards" />
                            </FrameLayout>

                            <TextView
                                android:id="@+id/tvStatCards"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="1"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:textColor="@color/text_primary" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Cards"
                                android:textSize="11sp"
                                android:textColor="@color/text_secondary" />
                        </LinearLayout>

                        <!-- Transactions stat -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">

                            <FrameLayout
                                android:layout_width="48dp"
                                android:layout_height="48dp"
                                android:layout_marginBottom="8dp">
                                <View
                                    android:layout_width="48dp"
                                    android:layout_height="48dp"
                                    android:background="@drawable/bg_stat_green" />
                                <ImageView
                                    android:layout_width="24dp"
                                    android:layout_height="24dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_trending_up"
                                    android:tint="@color/tint_059669"
                                    android:contentDescription="Transactions" />
                            </FrameLayout>

                            <TextView
                                android:id="@+id/tvStatTransactions"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:textColor="@color/text_primary" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Transactions"
                                android:textSize="11sp"
                                android:textColor="@color/text_secondary" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Menu: Personal Information -->
            <LinearLayout
                android:id="@+id/btnPersonalInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp"
                android:background="@drawable/bg_menu_item"
                android:layout_marginBottom="10dp"
                android:elevation="2dp">

                <FrameLayout
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginEnd="16dp">
                    <View android:layout_width="48dp" android:layout_height="48dp" android:background="@drawable/bg_stat_blue" />
                    <ImageView android:layout_width="24dp" android:layout_height="24dp" android:layout_gravity="center" android:src="@drawable/ic_person" android:tint="@color/tint_2563EB" android:contentDescription="Personal Info" />
                </FrameLayout>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Personal Information"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary" />

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_chevron_right"
                    android:tint="@color/tint_9CA3AF"
                    android:contentDescription="Arrow" />
            </LinearLayout>

            <!-- Menu: Banks and Cards -->
            <LinearLayout
                android:id="@+id/btnBanksCards"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp"
                android:background="@drawable/bg_menu_item"
                android:layout_marginBottom="10dp"
                android:elevation="2dp">

                <FrameLayout
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginEnd="16dp">
                    <View android:layout_width="48dp" android:layout_height="48dp" android:background="@drawable/bg_stat_purple" />
                    <ImageView android:layout_width="24dp" android:layout_height="24dp" android:layout_gravity="center" android:src="@drawable/ic_credit_card" android:tint="@color/tint_7C3AED" android:contentDescription="Cards" />
                </FrameLayout>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Banks and Cards"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary" />

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_chevron_right"
                    android:tint="@color/tint_9CA3AF"
                    android:contentDescription="Arrow" />
            </LinearLayout>

            <!-- Menu: Notifications (with badge) -->
            <LinearLayout
                android:id="@+id/btnNotifications"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp"
                android:background="@drawable/bg_menu_item"
                android:layout_marginBottom="10dp"
                android:elevation="2dp">

                <FrameLayout
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginEnd="16dp">
                    <View android:layout_width="48dp" android:layout_height="48dp" android:background="@drawable/bg_stat_orange" />
                    <ImageView android:layout_width="24dp" android:layout_height="24dp" android:layout_gravity="center" android:src="@drawable/ic_bell" android:tint="@color/tint_EA580C" android:contentDescription="Notifications" />
                </FrameLayout>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Notifications"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary" />

                <!-- Badge -->
                <TextView
                    android:id="@+id/tvNotifBadge"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:gravity="center"
                    android:textSize="10sp"
                    android:textColor="@color/white"
                    android:textStyle="bold"
                    android:background="@drawable/bg_dot_active"
                    android:layout_marginEnd="6dp"
                    android:visibility="gone" />

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_chevron_right"
                    android:tint="@color/tint_9CA3AF"
                    android:contentDescription="Arrow" />
            </LinearLayout>

            <!-- Menu: Settings -->
            <LinearLayout
                android:id="@+id/btnSettings"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp"
                android:background="@drawable/bg_menu_item"
                android:layout_marginBottom="10dp"
                android:elevation="2dp">

                <FrameLayout
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginEnd="16dp">
                    <View android:layout_width="48dp" android:layout_height="48dp" android:background="@drawable/bg_stat_gray" />
                    <ImageView android:layout_width="24dp" android:layout_height="24dp" android:layout_gravity="center" android:src="@drawable/ic_settings" android:tint="@color/tint_6B7280" android:contentDescription="Settings" />
                </FrameLayout>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Settings"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary" />

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_chevron_right"
                    android:tint="@color/tint_9CA3AF"
                    android:contentDescription="Arrow" />
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>
