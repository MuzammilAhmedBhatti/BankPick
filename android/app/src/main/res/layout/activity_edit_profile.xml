<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main" android:layout_width="match_parent" android:layout_height="match_parent" android:background="@color/white" android:fillViewport="true">
<LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="24dp">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical" android:layout_marginBottom="32dp">
        <ImageView android:id="@+id/ivBack" android:layout_width="40dp" android:layout_height="40dp" android:background="@drawable/bg_circle"
            android:src="@android:drawable/ic_menu_revert" android:padding="8dp" android:contentDescription="Back" />
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="@string/edit_profile" style="@style/HeaderTitle" android:gravity="center" />
        <View android:layout_width="40dp" android:layout_height="40dp" />
    </LinearLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_horizontal" android:orientation="vertical" android:layout_marginBottom="32dp">
        <ImageView android:layout_width="96dp" android:layout_height="96dp" android:background="@drawable/bg_circle" android:src="@android:drawable/ic_menu_myplaces"
            android:padding="16dp" android:layout_marginBottom="16dp" android:contentDescription="Profile" />
    </LinearLayout>

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/full_name" style="@style/LabelText" android:layout_marginBottom="8dp" />
    <EditText android:id="@+id/etFullName" android:layout_width="match_parent" android:layout_height="wrap_content" style="@style/InputFieldStyle"
        android:paddingStart="16dp" android:layout_marginBottom="20dp" android:importantForAutofill="no" />

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/email_address" style="@style/LabelText" android:layout_marginBottom="8dp" />
    <EditText android:id="@+id/etEmail" android:layout_width="match_parent" android:layout_height="wrap_content" style="@style/InputFieldStyle"
        android:paddingStart="16dp" android:inputType="textEmailAddress" android:layout_marginBottom="20dp" android:importantForAutofill="no" />

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/phone_number" style="@style/LabelText" android:layout_marginBottom="8dp" />
    <EditText android:id="@+id/etPhone" android:layout_width="match_parent" android:layout_height="wrap_content" style="@style/InputFieldStyle"
        android:paddingStart="16dp" android:inputType="phone" android:layout_marginBottom="20dp" android:importantForAutofill="no" />

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/birth_date" style="@style/LabelText" android:layout_marginBottom="8dp" />
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="24dp">
        <EditText android:id="@+id/etDay" android:layout_width="80dp" android:layout_height="wrap_content" style="@style/InputFieldStyle"
            android:paddingStart="16dp" android:gravity="center" android:hint="DD" android:layout_marginEnd="12dp" android:importantForAutofill="no" />
        <EditText android:id="@+id/etMonth" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" style="@style/InputFieldStyle"
            android:paddingStart="16dp" android:hint="Month" android:layout_marginEnd="12dp" android:importantForAutofill="no" />
        <EditText android:id="@+id/etYear" android:layout_width="96dp" android:layout_height="wrap_content" style="@style/InputFieldStyle"
            android:paddingStart="16dp" android:gravity="center" android:hint="YYYY" android:importantForAutofill="no" />
    </LinearLayout>

    <Button android:id="@+id/btnSave" android:layout_width="match_parent" android:layout_height="wrap_content" style="@style/ButtonPrimary" android:text="@string/save" />

    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/joined" android:textColor="@color/text_hint"
        android:gravity="center" android:layout_marginTop="16dp" android:textSize="14sp" />
</LinearLayout>
</ScrollView>
