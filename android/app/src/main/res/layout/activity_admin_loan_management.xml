<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F9FAFB">

    <!-- ═══════════════════════════════════════════
         HEADER  –  blue gradient + filter chips
         ═══════════════════════════════════════════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_admin_header"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="48dp"
        android:paddingBottom="24dp">

        <!-- ← Loan Requests title row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="20dp">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_chevron_left"
                android:padding="6dp"
                android:layout_marginEnd="12dp"
                android:importantForAccessibility="no"
                android:clickable="true"
                android:focusable="true"
                app:tint="#FFFFFF"
                xmlns:app="http://schemas.android.com/apk/res-auto" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Loan Requests"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF" />
        </LinearLayout>

        <!-- Filter chips: Pending / Approved / Rejected -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnFilterPending"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="Pending"
                android:textAllCaps="false"
                android:textSize="13sp"
                android:textColor="#1e3a8a"
                android:background="@drawable/bg_filter_chip_active"
                android:elevation="0dp"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:layout_marginEnd="10dp" />

            <Button
                android:id="@+id/btnFilterApproved"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="Approved"
                android:textAllCaps="false"
                android:textSize="13sp"
                android:textColor="#FFFFFF"
                android:background="@drawable/bg_filter_chip_inactive"
                android:elevation="0dp"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:layout_marginEnd="10dp" />

            <Button
                android:id="@+id/btnFilterRejected"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="Rejected"
                android:textAllCaps="false"
                android:textSize="13sp"
                android:textColor="#FFFFFF"
                android:background="@drawable/bg_filter_chip_inactive"
                android:elevation="0dp"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:insetTop="0dp"
                android:insetBottom="0dp" />

        </LinearLayout>
    </LinearLayout>

    <!-- ═══════════════════════════════════════════
         LOAN CARDS LIST
         ═══════════════════════════════════════════ -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvLoans"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="20dp"
        android:paddingBottom="20dp"
        android:clipToPadding="false"
        android:scrollbars="none" />

</LinearLayout>
