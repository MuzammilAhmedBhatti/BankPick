<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- ═══ Main Content ═══ -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:background="@color/app_background">

            <FrameLayout
                android:id="@+id/fragment_container"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <!-- Floating Nav Container -->
            <FrameLayout
                android:id="@+id/bottom_nav_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom"
                android:paddingBottom="16dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_floating_nav"
                    android:elevation="12dp"
                    android:orientation="horizontal"
                    android:padding="6dp">

                    <!-- Home -->
                    <LinearLayout
                        android:id="@+id/navItemHome"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp"
                        android:background="@drawable/bg_nav_active">
                        <ImageView
                            android:id="@+id/navIconHome"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_home"
                            android:tint="@color/tint_FFFFFF" />
                        <TextView
                            android:id="@+id/navTextHome"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="Home"
                            android:textSize="10sp"
                            android:textColor="@color/text_FFFFFF"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <!-- Cards -->
                    <LinearLayout
                        android:id="@+id/navItemCards"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp"
                        android:background="@android:color/transparent">
                        <ImageView
                            android:id="@+id/navIconCards"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_credit_card"
                            android:tint="@color/tint_9CA3AF" />
                        <TextView
                            android:id="@+id/navTextCards"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="Cards"
                            android:textSize="10sp"
                            android:textColor="@color/text_6B7280"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <!-- Stats -->
                    <LinearLayout
                        android:id="@+id/navItemStats"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp"
                        android:background="@android:color/transparent">
                        <ImageView
                            android:id="@+id/navIconStats"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_pie_chart"
                            android:tint="@color/tint_9CA3AF" />
                        <TextView
                            android:id="@+id/navTextStats"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="Stats"
                            android:textSize="10sp"
                            android:textColor="@color/text_6B7280"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <!-- Profile -->
                    <LinearLayout
                        android:id="@+id/navItemProfile"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp"
                        android:background="@android:color/transparent">
                        <ImageView
                            android:id="@+id/navIconProfile"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_person"
                            android:tint="@color/tint_9CA3AF" />
                        <TextView
                            android:id="@+id/navTextProfile"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="Profile"
                            android:textSize="10sp"
                            android:textColor="@color/text_6B7280"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>
            </FrameLayout>
        </LinearLayout>

        <!-- Blocked Account Overlay -->
        <LinearLayout
            android:id="@+id/blockedOverlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@color/bg_CC000000"
            android:visibility="gone"
            android:padding="32dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🚫"
                android:textSize="64sp"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Account Blocked"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Your account has been suspended. Please contact support to resolve this issue."
                android:textSize="15sp"
                android:textColor="@color/text_CCFFFFFF"
                android:gravity="center"
                android:layout_marginBottom="32dp" />

            <Button
                android:id="@+id/btnBlockedSignOut"
                android:layout_width="200dp"
                android:layout_height="52dp"
                android:text="Sign Out"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:background="@drawable/bg_badge_red"
                android:elevation="0dp" />
        </LinearLayout>
    </FrameLayout>

    <!-- ═══ Drawer ═══ -->
    <include
        layout="@layout/drawer_content"
        android:layout_width="300dp"
        android:layout_height="match_parent"
        android:layout_gravity="start" />

</androidx.drawerlayout.widget.DrawerLayout>
