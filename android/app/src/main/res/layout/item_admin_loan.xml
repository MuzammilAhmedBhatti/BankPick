<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="18dp">

        <!-- Top Row: User + Amount -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvLoanUserName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="John Doe"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary" />

                <TextView
                    android:id="@+id/tvLoanCardNumber"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Card: •••• 7852"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvLoanAmount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="$500.00"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/blue_600" />
        </LinearLayout>

        <!-- Reason -->
        <TextView
            android:id="@+id/tvLoanReason"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Reason: Medical expenses"
            android:textSize="13sp"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="4dp" />

        <!-- Timestamp -->
        <TextView
            android:id="@+id/tvLoanTimestamp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="May 7, 2026 12:00 AM"
            android:textSize="12sp"
            android:textColor="@color/text_hint"
            android:layout_marginBottom="14dp" />

        <!-- Action Buttons (shown only for pending) -->
        <LinearLayout
            android:id="@+id/llLoanActions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:visibility="gone">

            <Button
                android:id="@+id/btnApproveLoan"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:background="@drawable/bg_icon_green"
                android:text="✓ Approve"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:elevation="0dp"
                android:insetTop="0dp"
                android:insetBottom="0dp" />

            <Button
                android:id="@+id/btnRejectLoan"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:background="@drawable/bg_badge_red"
                android:text="✗ Reject"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:elevation="0dp"
                android:insetTop="0dp"
                android:insetBottom="0dp" />
        </LinearLayout>

        <!-- Status Badge (shown for non-pending) -->
        <TextView
            android:id="@+id/tvLoanStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="APPROVED"
            android:textSize="12sp"
            android:textColor="@color/white"
            android:background="@drawable/bg_circle_green"
            android:paddingHorizontal="12dp"
            android:paddingVertical="4dp"
            android:visibility="gone" />

    </LinearLayout>
</androidx.cardview.widget.CardView>
