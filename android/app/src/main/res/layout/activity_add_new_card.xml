<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/app_background">

    <!-- Header -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="16dp">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_circle"
            android:src="@drawable/ic_chevron_left"
            android:padding="8dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:contentDescription="@string/back" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Add New Card"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_centerInParent="true" />
    </RelativeLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingBottom="32dp">

            <!-- Card Preview -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="32dp"
                android:background="@drawable/bg_card_dark"
                android:clipToOutline="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <!-- Chip icon -->
                    <View
                        android:layout_width="40dp"
                        android:layout_height="30dp"
                        android:background="@drawable/bg_chip"
                        android:layout_marginBottom="24dp" />

                    <!-- Card Number -->
                    <TextView
                        android:id="@+id/tvPreviewCardNumber"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="4562 1122 4595 7852"
                        android:textSize="20sp"
                        android:textColor="@color/white"
                        android:letterSpacing="0.1"
                        android:fontFamily="monospace"
                        android:layout_marginBottom="16dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvPreviewHolderName"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="AR Jonson"
                                android:textSize="11sp"
                                android:textColor="@color/white"
                                android:alpha="0.7" />

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:layout_marginTop="4dp">

                                <LinearLayout
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:orientation="vertical"
                                    android:layout_marginEnd="16dp">

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Expiry Date"
                                        android:textSize="10sp"
                                        android:textColor="@color/white"
                                        android:alpha="0.7" />

                                    <TextView
                                        android:id="@+id/tvPreviewExpiry"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="24/2000"
                                        android:textSize="11sp"
                                        android:textColor="@color/white" />
                                </LinearLayout>

                                <LinearLayout
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:orientation="vertical">

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="CVV"
                                        android:textSize="10sp"
                                        android:textColor="@color/white"
                                        android:alpha="0.7" />

                                    <TextView
                                        android:id="@+id/tvPreviewCvv"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="6986"
                                        android:textSize="11sp"
                                        android:textColor="@color/white" />
                                </LinearLayout>
                            </LinearLayout>
                        </LinearLayout>

                        <!-- Mastercard logo -->
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="end">

                            <FrameLayout
                                android:layout_width="44dp"
                                android:layout_height="24dp"
                                android:layout_marginBottom="4dp">

                                <View
                                    android:layout_width="24dp"
                                    android:layout_height="24dp"
                                    android:background="@drawable/bg_mc_red"
                                    android:layout_gravity="start" />

                                <View
                                    android:layout_width="24dp"
                                    android:layout_height="24dp"
                                    android:background="@drawable/bg_mc_orange"
                                    android:layout_gravity="end" />
                            </FrameLayout>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Mastercard"
                                android:textSize="10sp"
                                android:textColor="@color/white" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </FrameLayout>

            <!-- Form -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cardholder Name"
                android:textSize="13sp"
                android:textColor="@color/text_hint"
                android:layout_marginBottom="8dp" />

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp">

                <EditText
                    android:id="@+id/etCardholderName"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:background="@drawable/bg_input_field"
                    android:paddingStart="48dp"
                    android:paddingEnd="16dp"
                    android:inputType="none"
                    android:hint="Tanya Myroniuk"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_hint"
                    android:textSize="15sp"
                    android:focusable="false"
                    android:cursorVisible="false"
                    android:importantForAutofill="no" />

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="center_vertical"
                    android:layout_marginStart="14dp"
                    android:src="@drawable/ic_person"
                    android:contentDescription="Person icon" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginEnd="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Expiry Date"
                        android:textSize="13sp"
                        android:textColor="@color/text_hint"
                        android:layout_marginBottom="8dp" />

                    <EditText
                        android:id="@+id/etExpiryDate"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:background="@drawable/bg_input_field"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:inputType="text"
                        android:hint="MM/YY"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_hint"
                        android:textSize="15sp"
                        android:importantForAutofill="no" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="3-digit CVV"
                        android:textSize="13sp"
                        android:textColor="@color/text_hint"
                        android:layout_marginBottom="8dp" />

                    <EditText
                        android:id="@+id/etCvv"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:background="@drawable/bg_input_field"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:inputType="numberPassword"
                        android:hint="***"
                        android:maxLength="3"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_hint"
                        android:textSize="15sp"
                        android:importantForAutofill="no" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Card Number"
                android:textSize="13sp"
                android:textColor="@color/text_hint"
                android:layout_marginBottom="8dp" />

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="32dp">

                <EditText
                    android:id="@+id/etCardNumber"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:background="@drawable/bg_input_field"
                    android:paddingStart="48dp"
                    android:paddingEnd="56dp"
                    android:inputType="number"
                    android:maxLength="19"
                    android:hint="4562 1122 4595 7852"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_hint"
                    android:textSize="15sp"
                    android:importantForAutofill="no" />

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="center_vertical"
                    android:layout_marginStart="14dp"
                    android:src="@drawable/ic_credit_card"
                    android:contentDescription="Card icon" />

                <FrameLayout
                    android:layout_width="44dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center_vertical|end"
                    android:layout_marginEnd="14dp">

                    <View
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:background="@drawable/bg_mc_red"
                        android:layout_gravity="start" />

                    <View
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:background="@drawable/bg_mc_orange"
                        android:layout_gravity="end" />
                </FrameLayout>
            </FrameLayout>

            <Button
                android:id="@+id/btnAddCard"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Add Card"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                android:background="@drawable/bg_button_primary" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
