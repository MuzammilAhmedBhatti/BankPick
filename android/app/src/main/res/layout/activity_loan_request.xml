<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_edit_profile_screen">

    <!-- Background orbs -->
    <View android:layout_width="280dp" android:layout_height="280dp"
        android:layout_alignParentTop="true" android:layout_alignParentEnd="true"
        android:layout_marginTop="-140dp" android:layout_marginEnd="-140dp"
        android:background="@drawable/bg_circle_purple" android:alpha="0.1" />
    <View android:layout_width="350dp" android:layout_height="350dp"
        android:layout_alignParentBottom="true" android:layout_alignParentStart="true"
        android:layout_marginBottom="-175dp" android:layout_marginStart="-175dp"
        android:background="@drawable/bg_circle_blue_light" android:alpha="0.1" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scrollbars="none"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:paddingTop="48dp">

            <!-- Header -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="32dp">

                <ImageView
                    android:id="@+id/btnBack"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_circle_white_solid"
                    android:elevation="4dp"
                    android:src="@drawable/ic_chevron_left"
                    android:padding="12dp"
                    android:tint="@color/black"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Request a Loan"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_centerInParent="true" />
            </RelativeLayout>

            <!-- Active Card Banner -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_card_gradient"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Loan will be credited to"
                        android:textSize="12sp"
                        android:textColor="@color/text_A0FFFFFF" />

                    <TextView
                        android:id="@+id/tvLoanCardNumber"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/white"
                        android:layout_marginTop="6dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="8dp">
                        <TextView
                            android:id="@+id/tvLoanCardType"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Mastercard"
                            android:textSize="13sp"
                            android:textColor="@color/text_A0FFFFFF" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Current Balance"
                            android:textSize="12sp"
                            android:textColor="@color/text_A0FFFFFF" />
                    </LinearLayout>
                    <TextView
                        android:id="@+id/tvLoanCardBalance"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="$0.00"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="@color/white"
                        android:gravity="end" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Existing Loan Warning -->
            <LinearLayout
                android:id="@+id/llExistingLoan"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_badge_red"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp"
                android:layout_marginBottom="16dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="⚠️  You already have a pending loan request."
                    android:textSize="14sp"
                    android:textColor="@color/white" />
            </LinearLayout>

            <!-- Amount Field -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">
                    <View
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:background="@drawable/bg_icon_blue"
                        android:layout_marginEnd="8dp" />
                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@drawable/ic_dollar"
                        android:tint="@color/blue_600"
                        android:layout_marginStart="-30dp"
                        android:layout_marginEnd="16dp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Loan Amount"
                        android:textSize="14sp"
                        android:textColor="@color/text_secondary" />
                </LinearLayout>
                <EditText
                    android:id="@+id/etLoanAmount"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:background="@drawable/bg_input_premium"
                    android:paddingHorizontal="20dp"
                    android:textSize="18sp"
                    android:textColor="@color/text_primary"
                    android:inputType="numberDecimal"
                    android:hint="e.g. 500.00" />
            </LinearLayout>

            <!-- Reason Field -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="32dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">
                    <View
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:background="@drawable/bg_icon_purple"
                        android:layout_marginEnd="8dp" />
                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@drawable/ic_document"
                        android:tint="@color/purple_600"
                        android:layout_marginStart="-30dp"
                        android:layout_marginEnd="16dp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Reason for Loan"
                        android:textSize="14sp"
                        android:textColor="@color/text_secondary" />
                </LinearLayout>
                <EditText
                    android:id="@+id/etLoanReason"
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:background="@drawable/bg_input_premium"
                    android:paddingHorizontal="20dp"
                    android:paddingVertical="16dp"
                    android:textSize="15sp"
                    android:textColor="@color/text_primary"
                    android:inputType="textMultiLine"
                    android:gravity="top"
                    android:hint="Explain why you need this loan..." />
            </LinearLayout>

            <!-- Submit Button -->
            <Button
                android:id="@+id/btnSubmitLoan"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:background="@drawable/bg_btn_gradient_blue"
                android:text="Submit Loan Request"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="17sp"
                android:textStyle="bold"
                android:elevation="8dp"
                android:layout_marginBottom="24dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</RelativeLayout>
