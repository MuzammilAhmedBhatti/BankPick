<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F8FAFC">

    <!-- Header -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_btn_gradient_blue"
        android:paddingHorizontal="20dp"
        android:paddingTop="48dp"
        android:paddingBottom="20dp">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_circle_white_solid"
            android:src="@drawable/ic_chevron_left"
            android:padding="8dp"
            android:tint="@color/black"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Loan Requests"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:layout_centerInParent="true" />
    </RelativeLayout>

    <!-- Filter Chips -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:background="@color/white"
        android:paddingHorizontal="16dp"
        android:paddingVertical="12dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnFilterPending"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="Pending"
                android:textAllCaps="false"
                android:textSize="13sp"
                android:textColor="@color/white"
                android:background="@drawable/bg_btn_gradient_blue"
                android:elevation="0dp"
                android:paddingHorizontal="20dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/btnFilterApproved"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="Approved"
                android:textAllCaps="false"
                android:textSize="13sp"
                android:textColor="@color/text_primary"
                android:background="@drawable/bg_quick_amount"
                android:elevation="0dp"
                android:paddingHorizontal="20dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/btnFilterRejected"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="Rejected"
                android:textAllCaps="false"
                android:textSize="13sp"
                android:textColor="@color/text_primary"
                android:background="@drawable/bg_quick_amount"
                android:elevation="0dp"
                android:paddingHorizontal="20dp"
                android:insetTop="0dp"
                android:insetBottom="0dp" />
        </LinearLayout>
    </HorizontalScrollView>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvLoans"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp"
        android:clipToPadding="false" />
</LinearLayout>
